{
  "manifest_version": 3,
  "name": "Support Tools",
  "version": "3.0.0",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "webNavigation",
    "clipboardWrite",
    "declarativeNetRequest"
  ],
  "background": {
    "service_worker": "functions/background.js"
  },
  "incognito": "split",
  "host_permissions": [
    "*://*.autotask.net/*",
    "*://*.rmm.datto.com/*",
    "*://*.itglue.com/*"
  ],
  "action": {
    "default_popup": "popups/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.autotask.net/*"
      ],
      "exclude_matches": [
        "*://*.autotask.net/help/Content/*",
        "*://*.autotask.net/help/content/*",
        "*://www.autotask.net/*"
      ],
      "js": [
        "functions/autotask/tabs/autotaskTabs.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.rmm.datto.com/*"
      ],
      "js": [
        "functions/dattormm/ITGlueOtpInterceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.rmm.datto.com/*"
      ],
      "js": [
        "functions/dattormm/ITGlueOtp.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.rmm.datto.com/*"
      ],
      "js": [
        "functions/dattormm/TrueStretch.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.rmm.datto.com/*"
      ],
      "js": [
        "functions/dattormm/ITGluePasswordCacheInterceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.rmm.datto.com/*"
      ],
      "js": [
        "functions/dattormm/ITGluePasswordCache.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.autotask.net/Autotask/Views/DispatcherWorkshop/DispatcherWorkshopView.aspx?MyCalendar=*"
      ],
      "js": [
        "functions/autotask/calendarChanger.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.autotask.net/Mvc/ServiceDesk*"
      ],
      "js": [
        "functions/autotask/templateManager.js",
        "functions/autotask/aiTaskHandler.js",
        "functions/hotkeyHandler.js"
      ],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "functions/dattormm/TrueStretchScript.js",
        "functions/autotask/tabs/autotaskTabsRoutes.js",
        "functions/autotask/tabs/autotaskTabsPageBridge.js"
      ],
      "matches": [
        "*://*.rmm.datto.com/*",
        "*://*.autotask.net/*"
      ]
    }
  ]
}
